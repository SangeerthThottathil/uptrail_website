{
  "testimonial_programmes": {
    "required": [
      "testimonial_id",
      "programme_slug"
    ],
    "properties": {
      "testimonial_id": {
        "description": "Note:\nThis is a Primary Key.<pk/>\nThis is a Foreign Key to `video_testimonials.id`.<fk table='video_testimonials' column='id'/>",
        "format": "integer",
        "type": "integer"
      },
      "programme_slug": {
        "description": "Note:\nThis is a Primary Key.<pk/>\nThis is a Foreign Key to `programmes.slug`.<fk table='programmes' column='slug'/>",
        "format": "text",
        "type": "string"
      }
    },
    "type": "object"
  },
  "programme_payment_options": {
    "required": [
      "id",
      "title",
      "button_label",
      "redirect_url",
      "created_at"
    ],
    "properties": {
      "id": {
        "description": "Note:\nThis is a Primary Key.<pk/>",
        "format": "bigint",
        "type": "integer"
      },
      "programme_slug": {
        "description": "Note:\nThis is a Foreign Key to `programmes.slug`.<fk table='programmes' column='slug'/>",
        "format": "text",
        "type": "string"
      },
      "pill_text": {
        "format": "text",
        "type": "string"
      },
      "title": {
        "format": "text",
        "type": "string"
      },
      "description": {
        "format": "text",
        "type": "string"
      },
      "bullet_points": {
        "format": "text[]",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "button_label": {
        "format": "text",
        "type": "string"
      },
      "redirect_url": {
        "format": "text",
        "type": "string"
      },
      "icon": {
        "default": "Wallet",
        "format": "text",
        "type": "string"
      },
      "display_order": {
        "default": 0,
        "format": "integer",
        "type": "integer"
      },
      "created_at": {
        "default": "timezone('utc'::text, now())",
        "format": "timestamp with time zone",
        "type": "string"
      }
    },
    "type": "object"
  },
  "testimonials": {
    "required": [
      "id",
      "quote",
      "name",
      "role",
      "programme",
      "rating",
      "order_index",
      "created_at"
    ],
    "properties": {
      "id": {
        "description": "Note:\nThis is a Primary Key.<pk/>",
        "format": "bigint",
        "type": "integer"
      },
      "quote": {
        "format": "text",
        "type": "string"
      },
      "name": {
        "format": "text",
        "type": "string"
      },
      "role": {
        "format": "text",
        "type": "string"
      },
      "programme": {
        "format": "text",
        "type": "string"
      },
      "rating": {
        "format": "integer",
        "type": "integer"
      },
      "order_index": {
        "default": 0,
        "format": "integer",
        "type": "integer"
      },
      "created_at": {
        "default": "now()",
        "format": "timestamp with time zone",
        "type": "string"
      },
      "is_featured": {
        "default": false,
        "format": "boolean",
        "type": "boolean"
      },
      "featured_title": {
        "format": "text",
        "type": "string"
      }
    },
    "type": "object"
  }
}